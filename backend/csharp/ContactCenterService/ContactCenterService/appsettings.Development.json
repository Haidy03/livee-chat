{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  // Dev overrides — point the external endpoints at the local SSH tunnel
  // (run ./tunnel-ccs.sh first). Everything else (DB names, S3, Azure, HubSpot)
  // is inherited from appsettings.json. Requires DOTNET_ENVIRONMENT=Development.
  "MongoDB": {
    // Single-node directConnection: replica-set discovery does not survive an
    // SSH tunnel (the driver would try to reconnect to the internal 172.31.x
    // member addresses). directConnection pins the driver to the tunnelled node.
    "ConnectionString": "mongodb://admin:admin@localhost:5010/?directConnection=true"
  },

  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672
  },

  // Voicemail AMI listener — point it at the tunnelled Asterisk manager port
  // (localhost:5038 -> 172.31.5.55:5038). Without this override the listener
  // dials the internal 172.31.5.55 directly, which is unreachable off-VPC, so
  // no VoicemailRecorded events are ever received when testing locally.
  // Username/Password/ReconnectDelaySeconds are inherited from appsettings.json.
  "VoicemailAmi": {
    "Host": "localhost",
    "Port": 5038
  }
}
