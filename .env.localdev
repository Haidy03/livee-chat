# Local dev overrides — loaded only via `npm run dev:local` (vite --mode localdev).
# Points the frontend at the locally-run API instead of the remote host.
# All other keys are inherited from .env.
VITE_API_URL="http://localhost:5151"
VITE_HUBSPOT_REDIRECT_URI="http://localhost:5151/integrations/hub_spot/oauth_redirect"
